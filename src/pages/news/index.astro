---
import { getCollection } from "astro:content";
import BaseLayout from "@/layouts/BaseLayout.astro";
import PageIntro from "@/components/ui/PageIntro.astro";
import Section from "@/components/ui/Section.astro";
import NewsPlanner from "@/components/news/NewsPlanner.astro";
import NewsCard from "@/components/news/NewsCard.astro";

const toUtcDayTimestamp = (date: Date) =>
    Date.UTC(date.getUTCFullYear(), date.getUTCMonth(), date.getUTCDate());

const entries = (await getCollection("news", ({ data }) => !data.draft)).sort(
    (a, b) => b.data.date.getTime() - a.data.date.getTime(),
);
const eventEntries = entries
    .filter((entry) => entry.data.isEvent)
    .sort((a, b) => a.data.date.getTime() - b.data.date.getTime());
const todayUtcDay = toUtcDayTimestamp(new Date());
const upcomingEventEntries = eventEntries.filter((entry) => {
    const visibilityDate = entry.data.eventEnd ?? entry.data.date;
    return toUtcDayTimestamp(visibilityDate) >= todayUtcDay;
});
const articleEntries = entries.filter((entry) => !entry.data.isEvent);
---

<BaseLayout
    title="Aktuelles | RFV Vorderrhön"
    description="Neuigkeiten, Trainingshinweise und kommende Termine von RFV Vorderrhön."
>
    <Section spaced={false} className="pb-0 pt-10 md:pt-16">
        <PageIntro
            eyebrow="Vereinsmeldungen"
            title="Aktuelles"
            description="Neue Informationen aus Training, Terminen und dem Rhythmus des Vereinsalltags"
        />
    </Section>
    <Section className="pt-8">
        <div
            class="grid gap-6 xl:grid-cols-[0.86fr_1.14fr] xl:items-start"
            data-news-planner-scope
        >
            <NewsPlanner entries={eventEntries} />
            <div class="grid gap-5" data-news-upcoming-events>
                <div class="max-w-2xl">
                    <p class="eyebrow">Termine</p>
                    <h2 class="mt-3 text-3xl md:text-4xl">Veranstaltungen</h2>
                    <p class="mt-4 text-[var(--color-soft-ink)]">
                        Kommende Termine mit Datum auf einen Blick
                    </p>
                </div>
                <div class="grid gap-5">
                    {upcomingEventEntries.map((entry) => (
                        <div
                            id={`news-${entry.slug}`}
                            class="scroll-mt-28"
                            data-upcoming-event
                            data-event-until={(
                                entry.data.eventEnd ?? entry.data.date
                            ).toISOString()}
                        >
                            <NewsCard
                                entry={entry}
                                plannerSlugs={entry.slug}
                            />
                        </div>
                    ))}
                </div>
                <div
                    class="panel p-6 md:p-7"
                    data-upcoming-empty
                    hidden={upcomingEventEntries.length > 0}
                >
                    <p class="text-sm uppercase tracking-[0.16em] text-[var(--color-moss)]">
                        Termine
                    </p>
                    <p class="mt-3 text-[var(--color-soft-ink)]">
                        Aktuell sind keine kommenden Veranstaltungen eingetragen.
                    </p>
                </div>
            </div>
        </div>

        <div class="mt-10 grid gap-5 md:mt-12">
            <div class="max-w-3xl">
                <p class="eyebrow">Artikel</p>
                <h2 class="mt-3 text-3xl md:text-4xl">
                    Neuigkeiten aus dem Verein
                </h2>
                <p class="mt-4 text-[var(--color-soft-ink)]">
                    Berichte, Hinweise und Rückblicke aus dem Vereinsalltag
                </p>
            </div>
            {
                articleEntries.length > 0 ? (
                    <div class="grid gap-5 lg:grid-cols-2">
                        {articleEntries.map((entry) => (
                            <div id={`news-${entry.slug}`} class="scroll-mt-28">
                                <NewsCard entry={entry} />
                            </div>
                        ))}
                    </div>
                ) : (
                    <div class="panel p-6 md:p-7">
                        <p class="text-sm uppercase tracking-[0.16em] text-[var(--color-moss)]">
                            Artikel
                        </p>
                        <p class="mt-3 text-[var(--color-soft-ink)]">
                            Aktuell gibt es noch keine zusätzlichen Beiträge.
                        </p>
                    </div>
                )
            }
        </div>
    </Section>
</BaseLayout>

<script is:inline>
    (() => {
        const toUtcDayTimestamp = (date) =>
            Date.UTC(
                date.getUTCFullYear(),
                date.getUTCMonth(),
                date.getUTCDate(),
            );

        const filterUpcomingEvents = () => {
            const scopes = Array.from(
                document.querySelectorAll("[data-news-upcoming-events]"),
            );

            scopes.forEach((scope) => {
                if (!(scope instanceof HTMLElement)) {
                    return;
                }

                const eventCards = Array.from(
                    scope.querySelectorAll("[data-upcoming-event]"),
                ).filter((card) => card instanceof HTMLElement);
                const emptyState = scope.querySelector("[data-upcoming-empty]");
                const todayUtcDay = toUtcDayTimestamp(new Date());
                let visibleCount = 0;

                eventCards.forEach((card) => {
                    const untilValue = card.dataset.eventUntil;
                    const untilDate = untilValue ? new Date(untilValue) : null;
                    const isUpcoming =
                        untilDate instanceof Date &&
                        !Number.isNaN(untilDate.getTime()) &&
                        toUtcDayTimestamp(untilDate) >= todayUtcDay;

                    card.hidden = !isUpcoming;

                    if (isUpcoming) {
                        visibleCount += 1;
                    }
                });

                if (emptyState instanceof HTMLElement) {
                    emptyState.hidden = visibleCount > 0;
                }
            });
        };

        filterUpcomingEvents();
        document.addEventListener("astro:page-load", filterUpcomingEvents);
    })();
</script>
