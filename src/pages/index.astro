---
import { getCollection } from "astro:content";
import BaseLayout from "@/layouts/BaseLayout.astro";
import Button from "@/components/ui/Button.astro";
import Section from "@/components/ui/Section.astro";
import HeroMotion from "@/components/home/HeroMotion";
import SectionReveal from "@/components/home/SectionReveal";
import NewsCard from "@/components/news/NewsCard.astro";
import { benefits, siteConfig, trainingHighlights, trustPoints } from "@/lib/site";

const allNews = await getCollection("news", ({ data }) => !data.draft);
const featuredNews = allNews
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 3);
---

<BaseLayout
  title="Rhine Field Vaulters | Equestrian Vaulting Club"
  description="Discover elegant, athletic vaulting training for children, teens, and adults. Book a trial session and get to know our calm, horse-first club culture."
>
  <Section className="pb-0 pt-10 md:pt-16">
    <div class="grid items-center gap-10 lg:grid-cols-[1.15fr_0.85fr]">
      <HeroMotion client:load />
      <div class="panel relative overflow-hidden p-8 md:p-10">
        <div class="absolute inset-x-8 top-0 h-px bg-[linear-gradient(90deg,transparent,rgba(47,71,50,0.38),transparent)]"></div>
        <p class="eyebrow">Trial Sessions Open</p>
        <h2 class="mt-5 text-3xl leading-tight md:text-4xl">Move with rhythm. Train with trust.</h2>
        <p class="mt-4 text-lg leading-8 text-[var(--color-soft-ink)]">
          Our club blends gymnastics, dance, and equestrian partnership into a disciplined sport that feels both graceful and grounded.
        </p>
        <div class="mt-8 flex flex-wrap gap-3">
          <Button href={siteConfig.trialUrl} external>Book Trial</Button>
          <Button href="/about-vaulting" variant="secondary">How Vaulting Works</Button>
        </div>
        <dl class="mt-10 grid gap-4 border-t border-[var(--color-line)] pt-6 sm:grid-cols-3">
          <div>
            <dt class="text-sm uppercase tracking-[0.14em] text-[var(--color-moss)]">Groups</dt>
            <dd class="mt-2 text-xl font-semibold">Beginner to advanced</dd>
          </div>
          <div>
            <dt class="text-sm uppercase tracking-[0.14em] text-[var(--color-moss)]">Focus</dt>
            <dd class="mt-2 text-xl font-semibold">Athletic + horse-first</dd>
          </div>
          <div>
            <dt class="text-sm uppercase tracking-[0.14em] text-[var(--color-moss)]">Location</dt>
            <dd class="mt-2 text-xl font-semibold">{siteConfig.location}</dd>
          </div>
        </dl>
      </div>
    </div>
  </Section>

  <Section>
    <SectionReveal client:visible>
      <div class="grid gap-8 lg:grid-cols-[0.9fr_1.1fr]">
        <div class="prose-flow">
          <span class="eyebrow">What Vaulting Is</span>
          <h2 class="text-3xl md:text-5xl">A team sport built on movement, courage, and partnership.</h2>
          <p class="text-lg leading-8 text-[var(--color-soft-ink)]">
            Equestrian vaulting combines gymnastics and dance on a moving horse. It develops balance, discipline, and body awareness while teaching athletes to work with care and precision.
          </p>
        </div>
        <div class="grid gap-4 md:grid-cols-3">
          {benefits.map((benefit) => (
            <article class="panel p-6">
              <h3 class="text-2xl">{benefit.title}</h3>
              <p class="mt-3 text-[var(--color-soft-ink)]">{benefit.text}</p>
            </article>
          ))}
        </div>
      </div>
    </SectionReveal>
  </Section>

  <Section className="pt-0">
    <SectionReveal client:visible>
      <div class="panel grid gap-8 overflow-hidden p-8 md:p-10 lg:grid-cols-[1fr_0.9fr]">
        <div class="prose-flow">
          <span class="eyebrow">Why Choose Us</span>
          <h2 class="text-3xl md:text-5xl">Clear coaching. Calm atmosphere. Serious care for horses.</h2>
          <p class="text-lg leading-8 text-[var(--color-soft-ink)]">
            Families join us because the environment feels steady from the first visit. Expectations are transparent, progression is structured, and training is ambitious without becoming chaotic.
          </p>
        </div>
        <ul class="space-y-4">
          {trustPoints.map((point) => (
            <li class="rounded-[1.4rem] border border-[var(--color-line)] bg-white/60 px-5 py-4 text-[var(--color-soft-ink)]">
              {point}
            </li>
          ))}
        </ul>
      </div>
    </SectionReveal>
  </Section>

  <Section className="pt-0">
    <SectionReveal client:visible>
      <div class="grid gap-6 lg:grid-cols-[1fr_1fr]">
        <div class="panel p-8 md:p-10">
          <span class="eyebrow">Training Overview</span>
          <h2 class="mt-4 text-3xl md:text-4xl">Every session balances preparation, technique, and horse partnership.</h2>
          <ul class="mt-6 space-y-4">
            {trainingHighlights.map((item) => (
              <li class="flex gap-3 text-[var(--color-soft-ink)]">
                <span class="mt-1 h-2.5 w-2.5 rounded-full bg-[var(--color-moss)]"></span>
                <span>{item}</span>
              </li>
            ))}
          </ul>
          <div class="mt-8">
            <Button href="/training" variant="secondary">Explore Training</Button>
          </div>
        </div>
        <div class="panel relative min-h-[22rem] overflow-hidden p-8 md:p-10">
          <div class="absolute inset-0 bg-[radial-gradient(circle_at_20%_20%,rgba(91,114,86,0.18),transparent_25%),radial-gradient(circle_at_75%_15%,rgba(183,139,53,0.14),transparent_22%),linear-gradient(145deg,rgba(255,255,255,0.64),rgba(239,227,207,0.78))]"></div>
          <div class="relative">
            <span class="eyebrow">Atmosphere</span>
            <h2 class="mt-4 max-w-sm text-3xl md:text-4xl">Elegant, athletic, and close to nature.</h2>
            <p class="mt-4 max-w-md text-lg leading-8 text-[var(--color-soft-ink)]">
              The visual identity stays restrained on purpose: soft sand tones, forest greens, curved surfaces, and enough movement to feel alive without becoming noisy.
            </p>
          </div>
          <div class="absolute bottom-8 right-8 grid w-48 rotate-[-8deg] gap-3">
            <div class="h-24 rounded-[1.6rem] bg-[rgba(47,71,50,0.85)]"></div>
            <div class="ml-10 h-20 rounded-[1.4rem] bg-[rgba(239,227,207,0.95)]"></div>
          </div>
        </div>
      </div>
    </SectionReveal>
  </Section>

  <Section className="pt-0">
    <SectionReveal client:visible>
      <div class="grid gap-6 lg:grid-cols-[0.95fr_1.05fr]">
        <div class="panel p-8 md:p-10">
          <span class="eyebrow">Pricing</span>
          <h2 class="mt-4 text-3xl md:text-4xl">Simple membership options with clear next steps.</h2>
          <p class="mt-4 text-lg leading-8 text-[var(--color-soft-ink)]">
            The pricing page is built to be understandable within seconds: group type, what is included, and the fastest path to booking a trial.
          </p>
          <div class="mt-8">
            <Button href="/pricing">View Pricing</Button>
          </div>
        </div>
        <div class="grid gap-4 md:grid-cols-2">
          <div class="panel p-6">
            <p class="text-sm uppercase tracking-[0.14em] text-[var(--color-moss)]">Starter</p>
            <p class="mt-3 text-4xl font-semibold">From 65 EUR</p>
            <p class="mt-4 text-[var(--color-soft-ink)]">Trial-friendly training for new vaulters building confidence and basics.</p>
          </div>
          <div class="panel p-6">
            <p class="text-sm uppercase tracking-[0.14em] text-[var(--color-moss)]">Squad</p>
            <p class="mt-3 text-4xl font-semibold">From 110 EUR</p>
            <p class="mt-4 text-[var(--color-soft-ink)]">More frequent sessions for committed athletes working on competition readiness.</p>
          </div>
        </div>
      </div>
    </SectionReveal>
  </Section>

  <Section className="pt-0">
    <SectionReveal client:visible>
      <div class="grid gap-6 lg:grid-cols-[1.05fr_0.95fr]">
        <div class="panel relative min-h-[24rem] overflow-hidden p-8 md:p-10">
          <div class="absolute inset-0 bg-[linear-gradient(135deg,rgba(47,71,50,0.94),rgba(91,114,86,0.78))]"></div>
          <div class="absolute -right-10 top-6 h-48 w-48 rounded-full border border-white/15"></div>
          <div class="absolute bottom-0 left-0 right-0 h-32 bg-[linear-gradient(180deg,transparent,rgba(0,0,0,0.18))]"></div>
          <div class="relative max-w-xl text-white">
            <span class="eyebrow !text-[rgba(255,255,255,0.7)] before:!bg-current">Visual Section</span>
            <h2 class="mt-4 text-3xl md:text-5xl">Training spaces shaped by routine, patience, and repeated practice.</h2>
            <p class="mt-4 text-lg leading-8 text-white/80">
              This section is intentionally atmospheric instead of image-heavy, keeping the first load fast while still giving the site a premium, editorial feel.
            </p>
          </div>
        </div>
        <div class="panel flex flex-col justify-between p-8 md:p-10">
          <div>
            <span class="eyebrow">Latest Updates</span>
            <h2 class="mt-4 text-3xl md:text-4xl">News from the club</h2>
          </div>
          <div class="mt-6 grid gap-4">
            {featuredNews.map((entry) => <NewsCard entry={entry} compact />)}
          </div>
        </div>
      </div>
    </SectionReveal>
  </Section>

  <Section className="pt-0">
    <SectionReveal client:visible>
      <div class="flex items-end justify-between gap-6">
        <div class="prose-flow max-w-2xl">
          <span class="eyebrow">From The News Section</span>
          <h2 class="text-3xl md:text-5xl">The latest three updates from the club.</h2>
          <p class="text-lg leading-8 text-[var(--color-soft-ink)]">
            Fresh posts from the news section help families see what is happening in training, scheduling, and club life.
          </p>
        </div>
        <div class="hidden md:block">
          <Button href="/news" variant="secondary">All News</Button>
        </div>
      </div>
      <div class="mt-8 grid gap-5 md:grid-cols-2 xl:grid-cols-3">
        {featuredNews.map((entry) => <NewsCard entry={entry} />)}
      </div>
      <div class="mt-6 md:hidden">
        <Button href="/news" variant="secondary">All News</Button>
      </div>
    </SectionReveal>
  </Section>

  <Section className="pt-0">
    <div class="panel overflow-hidden bg-[linear-gradient(135deg,#f2e4cb_0%,#efe7d7_45%,#fcfaf5_100%)] p-8 md:p-12">
      <div class="grid gap-8 lg:grid-cols-[1fr_auto] lg:items-center">
        <div class="prose-flow">
          <span class="eyebrow">Join Us</span>
          <h2 class="text-3xl md:text-5xl">Book a trial session and see how your athlete responds in the space.</h2>
          <p class="max-w-2xl text-lg leading-8 text-[var(--color-soft-ink)]">
            The website stays static and simple by design. All conversion points route to Google Forms so you can collect interest without adding backend complexity.
          </p>
        </div>
        <div class="flex flex-wrap gap-3">
          <Button href={siteConfig.applyUrl} external>Apply Now</Button>
          <Button href="/contact" variant="secondary">Contact the Club</Button>
        </div>
      </div>
    </div>
  </Section>
</BaseLayout>
