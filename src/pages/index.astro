    <Section className="pt-0">
        <div
            class="panel overflow-hidden bg-[linear-gradient(135deg,#f2e4cb_0%,#efe7d7_45%,#fcfaf5_100%)] p-8 md:p-12"
        >
            <div class="grid gap-8 lg:grid-cols-[1fr_auto] lg:items-center">
                <div class="prose-flow">
                    <span class="eyebrow">Mitmachen</span>
                    <h2 class="text-3xl md:text-5xl">
                        Buche ein Probetraining und erlebe, wie sich dein Kind
                        oder du selbst in der Gruppe fühlt.
                    </h2>
                    <p
                        class="max-w-2xl text-lg leading-8 text-[var(--color-soft-ink)]"
                    >
                        Die Website bleibt bewusst statisch und einfach. Alle
                        wichtigen Anfragen laufen ueber Google Forms, damit
                        Interesse ohne Backend-Komplexitaet gesammelt werden
                        kann.
                    </p>
                </div>
                <div class="flex flex-wrap gap-3">
                    <Button href={siteConfig.applyUrl}>Jetzt anmelden</Button>
                    <Button href="/contact" variant="secondary"
                        >Kontakt aufnehmen</Button
                    >
                </div>
            </div>
        </div>
    </Section>
</BaseLayout>
