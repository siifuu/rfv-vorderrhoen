---
import { getCollection, type CollectionEntry } from "astro:content";
import BaseLayout from "@/layouts/BaseLayout.astro";
import PageIntro from "@/components/ui/PageIntro.astro";
import Section from "@/components/ui/Section.astro";
import Button from "@/components/ui/Button.astro";
import PricingCards from "@/components/ui/PricingCards";
import FaqAccordion from "@/components/ui/FaqAccordion";
import { faqItems, siteConfig } from "@/lib/site";

interface Props {
  entry: CollectionEntry<"pages">;
}

const { entry } = Astro.props;
const { Content } = await entry.render();
const pricingEntries =
  entry.slug === "pricing"
    ? (await getCollection("pricing")).sort(
        (a, b) => (a.data.order ?? 99) - (b.data.order ?? 99)
      )
    : [];
---

<BaseLayout
  title={entry.data.seoTitle ?? `${entry.data.title} | Rhine Field Vaulters`}
  description={entry.data.seoDescription ?? entry.data.description}
>
  <Section className="pb-0 pt-10 md:pt-16">
    <PageIntro title={entry.data.title} description={entry.data.description} />
  </Section>
  <Section className="pt-8">
    <article class="panel rich-text px-6 py-8 md:px-10 md:py-12">
      <Content />
    </article>
  </Section>

  {
    entry.slug === "pricing" && (
      <>
        <Section className="pt-0">
          <PricingCards
            client:visible
            items={pricingEntries.map((item) => ({
              id: item.id,
              data: {
                name: item.data.name,
                priceLabel: item.data.priceLabel,
                description: item.data.description,
                features: item.data.features,
                highlighted: item.data.highlighted,
                ctaLabel: item.data.ctaLabel,
                ctaUrl: item.data.ctaUrl
              }
            }))}
          />
        </Section>
        <Section className="pt-0">
          <div class="grid gap-6 lg:grid-cols-[0.9fr_1.1fr]">
            <div class="panel p-8 md:p-10">
              <span class="eyebrow">Pricing Notes</span>
              <h2 class="mt-4 text-3xl md:text-4xl">Questions before you choose?</h2>
              <p class="mt-4 text-[var(--color-soft-ink)]">
                Start with a trial if you are unsure. We use the first visit to assess confidence, movement quality, and the best group fit.
              </p>
            </div>
            <FaqAccordion client:visible items={faqItems.slice(0, 3)} />
          </div>
        </Section>
        <Section className="pt-0">
          <div class="panel flex flex-col gap-6 p-8 md:flex-row md:items-center md:justify-between md:p-10">
            <div>
              <span class="eyebrow">Next Step</span>
              <h2 class="mt-4 text-3xl md:text-4xl">Book a trial or request placement.</h2>
            </div>
            <Button href={siteConfig.applyUrl} external>Open Google Form</Button>
          </div>
        </Section>
      </>
    )
  }

  {
    entry.slug === "faq" && (
      <Section className="pt-0">
        <FaqAccordion client:visible items={faqItems} />
      </Section>
    )
  }

  {
    entry.slug === "contact" && (
      <Section className="pt-0">
        <div class="grid gap-5 md:grid-cols-3">
          <div class="panel p-6">
            <p class="text-sm uppercase tracking-[0.16em] text-[var(--color-moss)]">Email</p>
            <a class="mt-3 block text-xl font-semibold" href={`mailto:${siteConfig.email}`}>{siteConfig.email}</a>
          </div>
          <div class="panel p-6">
            <p class="text-sm uppercase tracking-[0.16em] text-[var(--color-moss)]">Phone</p>
            <a class="mt-3 block text-xl font-semibold" href={`tel:${siteConfig.phone.replace(/\s+/g, "")}`}>{siteConfig.phone}</a>
          </div>
          <div class="panel p-6">
            <p class="text-sm uppercase tracking-[0.16em] text-[var(--color-moss)]">Application</p>
            <Button href={siteConfig.applyUrl} external className="mt-3">Open Form</Button>
          </div>
        </div>
      </Section>
    )
  }

  {
    entry.slug === "apply" && (
      <Section className="pt-0">
        <div class="panel flex flex-col gap-6 p-8 md:flex-row md:items-center md:justify-between md:p-10">
          <p class="max-w-2xl text-lg leading-8 text-[var(--color-soft-ink)]">
            Replace the placeholder Google Form URL in <code>src/lib/site.ts</code> and the pricing entries before publishing.
          </p>
          <Button href={siteConfig.applyUrl} external>Go To Application Form</Button>
        </div>
      </Section>
    )
  }
</BaseLayout>
