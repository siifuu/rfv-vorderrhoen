---
import { getCollection, type CollectionEntry } from "astro:content";
import BaseLayout from "@/layouts/BaseLayout.astro";
import PageIntro from "@/components/ui/PageIntro.astro";
import Section from "@/components/ui/Section.astro";
import Button from "@/components/ui/Button.astro";
import PricingCards from "@/components/ui/PricingCards";
import FaqAccordion from "@/components/ui/FaqAccordion";
import GoogleFormEmbed from "@/components/forms/GoogleFormEmbed.astro";
import { faqItems, siteConfig, socialLinks } from "@/lib/site";

interface Props {
    entry: CollectionEntry<"pages">;
}

const { entry } = Astro.props;
const { Content } = await entry.render();
const pricingEntries =
    entry.slug === "pricing"
        ? (await getCollection("pricing")).sort(
              (a, b) => (a.data.order ?? 99) - (b.data.order ?? 99),
          )
        : [];
---

<BaseLayout
    title={entry.data.seoTitle ?? `${entry.data.title} | RFV Vorderrhoen`}
    description={entry.data.seoDescription ?? entry.data.description}
>
    <Section spaced={false} className="pb-4 pt-10 md:pb-6 md:pt-16">
        <PageIntro
            title={entry.data.title}
            description={entry.data.description}
        />
    </Section>
    <Section spaced={false} className="pb-12 pt-8 md:pb-16">
        <article
            class="panel rich-text px-6 pb-8 pt-4 md:px-10 md:pb-12 md:pt-8"
        >
            <Content />
        </article>
    </Section>

    {
        entry.slug === "pricing" && (
            <>
                <Section className="pt-0">
                    <PricingCards
                        client:visible
                        items={pricingEntries.map((item) => ({
                            id: item.id,
                            data: {
                                name: item.data.name,
                                priceLabel: item.data.priceLabel,
                                description: item.data.description,
                                features: item.data.features,
                                highlighted: item.data.highlighted,
                                ctaLabel: item.data.ctaLabel,
                                ctaUrl: item.data.ctaUrl,
                            },
                        }))}
                    />
                </Section>
                <Section className="pt-0">
                    <div class="grid gap-6 lg:grid-cols-[0.9fr_1.1fr]">
                        <div class="panel p-8 md:p-10">
                            <span class="eyebrow">Hinweise zu den Preisen</span>
                            <h2 class="mt-4 text-3xl md:text-4xl">
                                Noch Fragen vor der Auswahl?
                            </h2>
                            <p class="mt-4 text-[var(--color-soft-ink)]">
                                Wenn du unsicher bist, starte mit einer
                                Probestunde. Beim ersten Termin schauen wir auf
                                Sicherheit, Bewegungsqualitaet und die passende
                                Gruppe.
                            </p>
                        </div>
                        <FaqAccordion
                            client:visible
                            items={faqItems.slice(0, 3)}
                        />
                    </div>
                </Section>
                <Section className="pt-0">
                    <div class="panel flex flex-col gap-6 p-8 md:flex-row md:items-center md:justify-between md:p-10">
                        <div>
                            <span class="eyebrow">Naechster Schritt</span>
                            <h2 class="mt-4 text-3xl md:text-4xl">
                                Probetraining buchen oder Gruppeneinteilung
                                anfragen.
                            </h2>
                        </div>
                        <Button href={siteConfig.applyUrl}>
                            Google-Formular oeffnen
                        </Button>
                    </div>
                </Section>
            </>
        )
    }

    {
        entry.slug === "faq" && (
            <Section className="pt-0">
                <FaqAccordion client:visible items={faqItems} />
            </Section>
        )
    }

    {
        entry.slug === "contact" && (
            <Section className="pt-0">
                <div class="grid gap-5 xl:grid-cols-[1.05fr_0.95fr] xl:items-start">
                    <div class="grid gap-5">
                        <div class="panel p-6">
                            <p class="text-sm uppercase tracking-[0.16em] text-[var(--color-moss)]">
                                E-Mail
                            </p>
                            <a
                                class="mt-3 block text-xl font-semibold"
                                href={`mailto:${siteConfig.email}`}
                            >
                                {siteConfig.email}
                            </a>
                        </div>
                        <div class="panel p-6">
                            <p class="text-sm uppercase tracking-[0.16em] text-[var(--color-moss)]">
                                Telefon
                            </p>
                            <a
                                class="mt-3 block text-xl font-semibold"
                                href={`tel:${siteConfig.phone.replace(/\s+/g, "")}`}
                            >
                                {siteConfig.phone}
                            </a>
                        </div>
                        <div class="panel p-6">
                            <p class="text-sm uppercase tracking-[0.16em] text-[var(--color-moss)]">
                                Anmeldung
                            </p>
                            <Button
                                href={siteConfig.applyUrl}
                                className="mt-3"
                            >
                                Formular oeffnen
                            </Button>
                        </div>
                    </div>

                    <div class="panel p-6 md:p-8">
                        <span class="eyebrow">Socials</span>
                        <h2 class="mt-4 text-3xl md:text-4xl">
                            Instagram-Accounts fuer Verein und Teams
                        </h2>
                        <div class="mt-6 grid gap-4">
                            {
                                socialLinks.map((item) => (
                                    <a
                                        class="rounded-[1.3rem] border border-[var(--color-line)] bg-white/55 px-5 py-4 transition hover:-translate-y-0.5 hover:border-[var(--color-moss)]"
                                        href={item.href}
                                        target="_blank"
                                        rel="noreferrer"
                                    >
                                        <span class="block text-xs uppercase tracking-[0.14em] text-[var(--color-moss)]">
                                            {item.platform}
                                        </span>
                                        <span class="mt-2 block text-xl font-semibold">
                                            {item.label}
                                        </span>
                                        <span class="mt-1 block text-[var(--color-soft-ink)]">
                                            {item.handle}
                                        </span>
                                    </a>
                                ))
                            }
                        </div>
                    </div>
                </div>
            </Section>
        )
    }

    {
        entry.slug === "trial" && (
            <Section className="pt-0">
                <GoogleFormEmbed
                    title="Probetraining direkt anfragen"
                    description="Nutze das eingebettete Formular fuer die erste Anfrage. Wenn die Einbettung in deinem Browser nicht korrekt geladen wird, kannst du das Formular jederzeit ueber den Direktlink bei Google oeffnen."
                    formUrl={siteConfig.trialFormUrl}
                />
            </Section>
        )
    }

    {
        entry.slug === "apply" && (
            <Section className="pt-0">
                <GoogleFormEmbed
                    title="Anmeldung direkt ausfuellen"
                    description="Diese Seite sammelt Mitgliedschafts- und Platzanfragen direkt im eingebetteten Formular. Wenn die Einbettung in deinem Browser nicht korrekt geladen wird, kannst du das Formular jederzeit ueber den Direktlink bei Google oeffnen."
                    formUrl={siteConfig.applyFormUrl}
                />
            </Section>
        )
    }
</BaseLayout>
