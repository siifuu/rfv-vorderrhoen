---
import { getCollection, type CollectionEntry } from "astro:content";
import BaseLayout from "@/layouts/BaseLayout.astro";
import PageIntro from "@/components/ui/PageIntro.astro";
import Section from "@/components/ui/Section.astro";
import Button from "@/components/ui/Button.astro";
import MembershipCards from "@/components/ui/MembershipCards";
import FaqAccordion from "@/components/ui/FaqAccordion";
import GoogleFormEmbed from "@/components/forms/GoogleFormEmbed.astro";
import LocationMap from "@/components/ui/LocationMap.astro";
import { faqItems, siteConfig, socialLinks } from "@/lib/site";

interface Props {
    entry: CollectionEntry<"pages">;
}

type PricingEntry = CollectionEntry<"pricing">;
type MembershipSection = {
    key: string;
    eyebrow: string;
    title: string;
    description: string;
    items: PricingEntry[];
};

const membershipGroupLabel = "Vereinsmitgliedschaft";
const trainingGroupLabel = "Aktive Trainingsmitgliedschaft";

const { entry } = Astro.props;
const { Content } = await entry.render();
const pricingEntries =
    entry.slug === "pricing"
        ? (await getCollection("pricing")).sort(
              (a, b) => (a.data.order ?? 99) - (b.data.order ?? 99),
          )
        : [];
const membershipSections: MembershipSection[] = [];

if (entry.slug === "pricing") {
    const clubMemberships = pricingEntries.filter(
        (item) => item.data.groupLabel === membershipGroupLabel,
    );
    const trainingMemberships = pricingEntries.filter(
        (item) => item.data.groupLabel === trainingGroupLabel,
    );
    const additionalMemberships = pricingEntries.filter(
        (item) =>
            item.data.groupLabel !== membershipGroupLabel &&
            item.data.groupLabel !== trainingGroupLabel,
    );

    if (clubMemberships.length > 0) {
        membershipSections.push({
            key: "club-memberships",
            eyebrow: "Verein",
            title: "Vereinsmitgliedschaft",
            description: "Die passende Mitgliedschaft im Verein.",
            items: clubMemberships,
        });
    }

    if (trainingMemberships.length > 0) {
        membershipSections.push({
            key: "active-training",
            eyebrow: "Training",
            title: "Aktive Teilnahme",
            description:
                "Zusätzlich zur Vereinsmitgliedschaft für aktive Voltigiererinnen und Voltigierer.",
            items: trainingMemberships,
        });
    }

    if (additionalMemberships.length > 0) {
        membershipSections.push({
            key: "additional-options",
            eyebrow: "Zusätzlich",
            title: "Weitere Optionen",
            description: "Individuell nach Absprache.",
            items: additionalMemberships,
        });
    }
}
---

<BaseLayout
    title={entry.data.seoTitle ?? `${entry.data.title} | RFV Vorderrhön`}
    description={entry.data.seoDescription ?? entry.data.description}
>
    <Section spaced={false} className="pb-4 pt-10 md:pb-6 md:pt-16">
        <PageIntro
            title={entry.data.title}
            description={entry.data.description}
        />
    </Section>
    {
        entry.body && (
            <Section spaced={false} className="pb-8 pt-8 md:pb-10">
                <article class="panel rich-text px-6 pb-8 pt-4 md:px-10 md:pb-10 md:pt-6">
                    <Content />
                </article>
            </Section>
        )
    }

    {
        entry.slug === "pricing" && (
            <>
                {membershipSections.map((section) => (
                    <Section
                        spaced={false}
                        className="pb-8 pt-0 md:pb-10"
                        id={section.key}
                    >
                        <div class="max-w-3xl">
                            <span class="eyebrow">{section.eyebrow}</span>
                            <h2 class="mt-3 text-3xl md:text-4xl">
                                {section.title}
                            </h2>
                            <p class="mt-4 text-[var(--color-soft-ink)]">
                                {section.description}
                            </p>
                        </div>
                        <div class="mt-6">
                            <MembershipCards
                                client:visible
                                items={section.items.map((item) => ({
                                    id: item.id,
                                    data: {
                                        name: item.data.name,
                                        description: item.data.description,
                                        features: item.data.features,
                                        highlighted: item.data.highlighted,
                                    },
                                }))}
                            />
                        </div>
                    </Section>
                ))}

                <Section spaced={false} className="pb-8 pt-0 md:pb-10">
                    <div class="panel p-8 md:p-10">
                        <span class="eyebrow">Wichtig</span>
                        <ul class="mt-6 space-y-3 text-sm text-[var(--color-soft-ink)]">
                            <li class="flex gap-3">
                                <span class="mt-1.5 h-2 w-2 rounded-full bg-[var(--color-moss)]" />
                                <span>
                                    Vereinsmitgliedschaft und aktive Teilnahme
                                    werden getrennt betrachtet.
                                </span>
                            </li>
                            <li class="flex gap-3">
                                <span class="mt-1.5 h-2 w-2 rounded-full bg-[var(--color-moss)]" />
                                <span>
                                    Fördermitgliedschaft ist ohne regelmäßige
                                    aktive Teilnahme gedacht.
                                </span>
                            </li>
                            <li class="flex gap-3">
                                <span class="mt-1.5 h-2 w-2 rounded-full bg-[var(--color-moss)]" />
                                <span>
                                    Reitbeteiligungen und Details klären wir
                                    individuell.
                                </span>
                            </li>
                        </ul>
                    </div>
                </Section>

                <Section spaced={false} className="pb-8 pt-0 md:pb-10">
                    <div class="panel flex flex-col gap-6 p-8 md:flex-row md:items-center md:justify-between md:p-10">
                        <div>
                            <span class="eyebrow">Anfrage</span>
                            <h2 class="mt-4 text-3xl md:text-4xl">
                                Mitgliedschaft oder Probetraining anfragen.
                            </h2>
                        </div>
                        <Button href={siteConfig.signupUrl}>
                            Anfrage starten
                        </Button>
                    </div>
                </Section>
            </>
        )
    }

    {
        entry.slug === "faq" && (
            <Section className="pt-0">
                <FaqAccordion client:visible items={faqItems} />
            </Section>
        )
    }

    {
        entry.slug === "contact" && (
            <Section className="pt-0">
                <div class="grid gap-5">
                    <div class="grid gap-5 xl:grid-cols-[1.05fr_0.95fr] xl:items-start">
                        <div class="grid gap-5">
                            <div class="panel p-6">
                                <p class="text-sm uppercase tracking-[0.16em] text-[var(--color-moss)]">
                                    E-Mail
                                </p>
                                <a
                                    class="mt-3 block text-xl font-semibold"
                                    href={`mailto:${siteConfig.email}`}
                                >
                                    {siteConfig.email}
                                </a>
                            </div>
                            <div class="panel p-6">
                                <p class="text-sm uppercase tracking-[0.16em] text-[var(--color-moss)]">
                                    Telefon
                                </p>
                                <a
                                    class="mt-3 block text-xl font-semibold"
                                    href={`tel:${siteConfig.phone.replace(/\s+/g, "")}`}
                                >
                                    {siteConfig.phone}
                                </a>
                            </div>
                            <div class="panel p-6">
                                <p class="text-sm uppercase tracking-[0.16em] text-[var(--color-moss)]">
                                    Probetraining
                                </p>
                                <Button
                                    href={siteConfig.signupUrl}
                                    className="mt-3"
                                >
                                    Probetraining anfragen
                                </Button>
                            </div>
                        </div>

                        <div class="panel p-6 md:p-8">
                            <span class="eyebrow">Socials</span>
                            <h2 class="mt-4 text-3xl md:text-4xl">
                                Instagram-Accounts für Verein und Teams
                            </h2>
                            <div class="mt-6 grid gap-4">
                                {socialLinks.map((item) => (
                                    <a
                                        class="relative overflow-hidden rounded-[1.3rem] border border-[var(--color-line)] bg-white/55 px-5 py-4 pr-18 transition hover:-translate-y-0.5 hover:border-[var(--color-moss)]"
                                        href={item.href}
                                        target="_blank"
                                        rel="noreferrer"
                                    >
                                        <span class="pointer-events-none absolute right-4 top-1/2 -translate-y-1/2 text-[var(--color-moss)] opacity-18">
                                            <svg
                                                aria-hidden="true"
                                                viewBox="0 0 24 24"
                                                class="h-12 w-12"
                                                fill="none"
                                                stroke="currentColor"
                                                stroke-width="1.5"
                                                stroke-linecap="round"
                                                stroke-linejoin="round"
                                            >
                                                <rect
                                                    x="3.5"
                                                    y="3.5"
                                                    width="17"
                                                    height="17"
                                                    rx="5"
                                                />
                                                <circle
                                                    cx="12"
                                                    cy="12"
                                                    r="4"
                                                />
                                                <circle
                                                    cx="17.35"
                                                    cy="6.65"
                                                    r="0.8"
                                                    fill="currentColor"
                                                    stroke="none"
                                                />
                                            </svg>
                                        </span>
                                        <span class="block text-xs uppercase tracking-[0.14em] text-[var(--color-moss)]">
                                            {item.platform}
                                        </span>
                                        <span class="mt-2 block text-xl font-semibold">
                                            {item.label}
                                        </span>
                                        <span class="mt-1 block text-[var(--color-soft-ink)]">
                                            {item.handle}
                                        </span>
                                    </a>
                                ))}
                            </div>
                        </div>
                    </div>

                    <LocationMap
                        eyebrow="Anfahrt"
                        title="So findest du den Verein"
                        description="Nutze die eingebettete Karte für die Orientierung vor Ort oder öffne den Standort direkt in Google Maps für deine Anfahrt."
                    />
                </div>
            </Section>
        )
    }

    {
        entry.slug === "probetraining-anfragen" && (
            <Section className="pt-0">
                <GoogleFormEmbed
                    title="Probetraining anfragen"
                    description="Wenn die Einbettung in deinem Browser nicht korrekt geladen wird, kannst du das Formular jederzeit über den Direktlink bei Google öffnen."
                    formUrl={siteConfig.signupFormUrl}
                />
            </Section>
        )
    }

    {
        false && (
            <Section className="pt-0">
                <GoogleFormEmbed
                    title="Anmeldung direkt ausfüllen"
                    description="Wenn die Einbettung in deinem Browser nicht korrekt geladen wird, kannst du das Formular jederzeit über den Direktlink bei Google öffnen."
                    formUrl={siteConfig.signupFormUrl}
                />
            </Section>
        )
    }
</BaseLayout>
