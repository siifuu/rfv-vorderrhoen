---
import type { CollectionEntry } from "astro:content";
import { withBase } from "@/lib/paths";
import { formatDate } from "@/lib/utils";

interface Props {
  entry: CollectionEntry<"news">;
  compact?: boolean;
  plannerSlugs?: string;
}

const { entry, compact = false, plannerSlugs } = Astro.props;
const eventDay = new Intl.DateTimeFormat("de-DE", {
  day: "2-digit",
  timeZone: "UTC",
}).format(entry.data.date);
const eventMonth = new Intl.DateTimeFormat("de-DE", {
  month: "short",
  timeZone: "UTC",
})
  .format(entry.data.date)
  .replace(".", "")
  .toUpperCase();
---

<a
  href={withBase(`/news/${entry.slug}`)}
  class="group block h-full rounded-[var(--radius-lg)] focus-visible:outline-none"
  data-planner-linked-card={plannerSlugs ? "" : undefined}
  data-planner-slugs={plannerSlugs}
>
  <article
    class:list={[
      "panel relative h-full overflow-hidden p-5 transition-all duration-300 ease-[cubic-bezier(0.22,1,0.36,1)] group-hover:-translate-y-1.5 group-hover:border-[rgba(47,71,50,0.24)] group-hover:shadow-[0_24px_58px_rgba(24,31,25,0.14)] group-focus-visible:-translate-y-1.5 group-focus-visible:border-[rgba(47,71,50,0.24)] group-focus-visible:shadow-[0_24px_58px_rgba(24,31,25,0.14)] md:p-6",
      entry.data.isEvent &&
        "border-[rgba(47,71,50,0.18)] bg-[linear-gradient(145deg,rgba(255,252,247,0.94),rgba(243,248,241,0.82))]",
    ]}
  >
    <div class="pointer-events-none absolute inset-x-6 top-0 h-px origin-left scale-x-60 bg-[linear-gradient(90deg,transparent,rgba(47,71,50,0.38),transparent)] opacity-60 transition duration-300 group-hover:scale-x-100 group-hover:opacity-100 group-focus-visible:scale-x-100 group-focus-visible:opacity-100"></div>
    <div class="news-card-glow pointer-events-none absolute -right-10 -top-4 h-56 w-56 bg-[radial-gradient(circle,rgba(91,114,86,0.36)_0%,rgba(91,114,86,0.22)_34%,transparent_72%)]"></div>
    {
      entry.data.isEvent ? (
        <div class:list={["relative z-10 grid items-start gap-4", compact ? "grid-cols-[4.6rem_1fr]" : "grid-cols-[5.4rem_1fr]"]}>
          <div class:list={[
            "rounded-[1.35rem] border border-[rgba(247,240,226,0.14)] bg-[linear-gradient(145deg,rgba(47,71,50,0.98),rgba(91,114,86,0.84))] px-3 py-3 text-center text-[var(--color-cream-strong)] shadow-[0_14px_28px_rgba(24,31,25,0.16)]",
            compact ? "pt-3" : "pt-4",
          ]}>
            <span class="block text-[0.68rem] font-semibold uppercase tracking-[0.16em] text-[rgba(247,240,226,0.78)]">
              {eventMonth}
            </span>
            <span class:list={["mt-2 block font-semibold leading-none", compact ? "text-4xl" : "text-5xl"]}>
              {eventDay}
            </span>
          </div>
          <div class="min-w-0">
            <div class="flex flex-wrap items-center gap-2">
              <span class="rounded-full border border-[rgba(47,71,50,0.12)] bg-white/76 px-3 py-1 text-[0.68rem] font-semibold uppercase tracking-[0.14em] text-[var(--color-forest)]">
                Veranstaltung
              </span>
              <p
                class="text-xs font-semibold uppercase tracking-[0.16em] text-[var(--color-moss)] transition duration-300 group-hover:text-[var(--color-forest)] group-focus-visible:text-[var(--color-forest)]"
                data-news-card-meta
              >
                {formatDate(entry.data.date)}
              </p>
            </div>
            <h3
              class:list={["mt-3 leading-tight transition duration-300 group-hover:text-[var(--color-forest)] group-focus-visible:text-[var(--color-forest)]", compact ? "text-xl" : "text-2xl"]}
              data-news-card-title
            >
              {entry.data.title}
            </h3>
            <p
              class="mt-3 text-[var(--color-soft-ink)] transition duration-300 group-hover:text-[var(--color-ink)] group-focus-visible:text-[var(--color-ink)]"
              data-news-card-description
            >
              {entry.data.description}
            </p>
          </div>
        </div>
      ) : (
        <>
          <p
            class="relative text-xs font-semibold uppercase tracking-[0.16em] text-[var(--color-moss)] transition duration-300 group-hover:text-[var(--color-forest)] group-focus-visible:text-[var(--color-forest)]"
            data-news-card-meta
          >
            {formatDate(entry.data.date)}
          </p>
          <h3
            class:list={["relative mt-3 leading-tight transition duration-300 group-hover:text-[var(--color-forest)] group-focus-visible:text-[var(--color-forest)]", compact ? "text-xl" : "text-2xl"]}
            data-news-card-title
          >
            {entry.data.title}
          </h3>
          <p
            class="relative mt-3 text-[var(--color-soft-ink)] transition duration-300 group-hover:text-[var(--color-ink)] group-focus-visible:text-[var(--color-ink)]"
            data-news-card-description
          >
            {entry.data.description}
          </p>
        </>
      )
    }
  </article>
</a>

<style is:global>
  [data-planner-linked-card][data-planner-highlighted] article {
    transform: translateY(-0.375rem);
    border-color: rgba(47, 71, 50, 0.24);
    box-shadow: 0 24px 58px rgba(24, 31, 25, 0.14);
  }

  [data-planner-linked-card][data-planner-highlighted] [data-news-card-title],
  [data-planner-linked-card][data-planner-highlighted] [data-news-card-meta] {
    color: var(--color-forest);
  }

  [data-planner-linked-card][data-planner-highlighted] [data-news-card-description] {
    color: var(--color-ink);
  }
</style>
