---
import type { CollectionEntry } from "astro:content";
import HorseVisual from "@/components/horses/HorseVisual.astro";
import { withBase } from "@/lib/paths";

interface Props {
    entry: CollectionEntry<"horses">;
}

const { entry } = Astro.props;
---

<a href={withBase(`/pferde/${entry.slug}/`)} class="group block h-full">
    <article
        class="panel relative flex h-full flex-col overflow-hidden p-3 transition duration-300 ease-[cubic-bezier(0.22,1,0.36,1)] group-hover:-translate-y-1 group-hover:shadow-[var(--shadow-strong)] group-focus-visible:-translate-y-1 group-focus-visible:shadow-[var(--shadow-strong)] sm:p-4"
    >
        <div
            class="absolute -right-12 top-0 h-36 w-36 rounded-full bg-[radial-gradient(circle,rgba(91,114,86,0.2)_0%,rgba(91,114,86,0.08)_36%,transparent_72%)] opacity-0 blur-3xl transition duration-500 ease-[cubic-bezier(0.22,1,0.36,1)] group-hover:opacity-100 group-focus-visible:opacity-100"
        >
        </div>
        <div class="relative flex h-full flex-col">
            <HorseVisual entry={entry} compact />
            <div class="mt-4 flex items-start justify-between gap-4 sm:mt-5">
                <h3 class="text-2xl leading-tight sm:text-3xl">{entry.data.name}</h3>
            </div>
            <p class="mt-3 text-sm text-[var(--color-soft-ink)] sm:mt-4 sm:text-base">
                {entry.data.description}
            </p>
            <dl
                class="mt-5 grid gap-3 border-t border-[var(--color-line)] pt-4 sm:mt-6 sm:gap-4 sm:pt-5"
            >
                <div>
                    <dt
                        class="text-xs uppercase tracking-[0.14em] text-[var(--color-moss)]"
                    >
                        Rasse
                    </dt>
                    <dd class="mt-2 text-sm text-[var(--color-ink)] sm:text-base">
                        {entry.data.race}
                    </dd>
                </div>
                <div>
                    <dt
                        class="text-xs uppercase tracking-[0.14em] text-[var(--color-moss)]"
                    >
                        Im Verein seit
                    </dt>
                    <dd class="mt-2 text-sm text-[var(--color-ink)] sm:text-base">
                        {entry.data.clubSince}
                    </dd>
                </div>
            </dl>
            <span
                class="mt-auto inline-flex items-center gap-2 pt-5 text-sm font-semibold text-[var(--color-forest)] sm:pt-6"
            >
                Profil ansehen
                <span aria-hidden="true">-&gt;</span>
            </span>
        </div>
    </article>
</a>
