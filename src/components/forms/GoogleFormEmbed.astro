---
import Button from "@/components/ui/Button.astro";
import { getGoogleFormEmbedUrl } from "@/lib/googleForms";

interface Props {
    title: string;
    description: string;
    formUrl: string;
}

const { title, description, formUrl } = Astro.props;
const embedUrl = getGoogleFormEmbedUrl(formUrl);
---

<div class="panel overflow-hidden">
    <div class="border-b border-[var(--color-line)] px-6 py-6 md:px-8 md:py-8">
        <span class="eyebrow">Google Form</span>
        <h2 class="mt-4 text-3xl md:text-4xl">{title}</h2>
        <p class="mt-4 max-w-3xl text-lg leading-8 text-[var(--color-soft-ink)]">
            {description}
        </p>
        <div class="mt-6">
            <Button href={formUrl} variant="secondary" external>
                Formular direkt bei Google oeffnen
            </Button>
        </div>
    </div>
    <div class="bg-[rgba(255,255,255,0.72)] p-2 md:p-3">
        <iframe
            src={embedUrl}
            title={title}
            loading="lazy"
            referrerpolicy="strict-origin-when-cross-origin"
            class="h-[1180px] w-full rounded-[1.35rem] border-0 bg-white md:h-[1260px]"
        ></iframe>
    </div>
</div>
