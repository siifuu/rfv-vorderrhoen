---
import Button from "@/components/ui/Button.astro";
import { siteConfig } from "@/lib/site";

interface Props {
    eyebrow?: string;
    title?: string;
    description?: string;
    iframeClassName?: string;
}

const {
    eyebrow = "Trainingsort",
    title = "Hier findest du uns",
    description = "Unser Training findet in Künzell statt. Du kannst den Standort direkt in Google Maps öffnen oder die Karte hier auf der Seite nutzen.",
    iframeClassName = "h-full min-h-[20rem] md:min-h-[24rem]",
} = Astro.props;

const locationQuery = encodeURIComponent(siteConfig.location);
const mapsEmbedUrl = `https://www.google.com/maps?q=${locationQuery}&output=embed`;
const mapsUrl = `https://www.google.com/maps/search/?api=1&query=${locationQuery}`;
---

<div class="panel relative isolate overflow-hidden">
    <div
        class="absolute inset-0 bg-[radial-gradient(circle_at_18%_18%,rgba(91,114,86,0.18),transparent_26%),radial-gradient(circle_at_82%_14%,rgba(183,139,53,0.12),transparent_22%),linear-gradient(145deg,rgba(255,255,255,0.52),rgba(239,227,207,0.68))]"
        aria-hidden="true"
    >
    </div>

    <div
        class="relative grid gap-0 lg:grid-cols-[0.88fr_1.12fr] lg:items-stretch"
    >
        <div
            class="border-b border-[var(--color-line)] px-6 py-6 md:px-8 md:py-8 lg:border-b-0 lg:border-r"
        >
            <span class="eyebrow">{eyebrow}</span>
            <h2 class="mt-4 text-3xl md:text-4xl">{title}</h2>
            <p
                class="mt-4 max-w-xl text-lg leading-8 text-[var(--color-soft-ink)]"
            >
                {description}
            </p>

            <div
                class="mt-6 rounded-[1.4rem] border border-[var(--color-line)] bg-white/60 p-5 shadow-[var(--shadow-soft)]"
            >
                <p class="text-xs uppercase tracking-[0.14em] text-[var(--color-moss)]">
                    Adresse
                </p>
                <p class="mt-3 text-base font-semibold leading-7 text-[var(--color-ink)]">
                    {siteConfig.location}
                </p>
            </div>

            <div class="mt-6 flex flex-wrap gap-3">
                <Button href={mapsUrl} variant="secondary" external>
                    In Google Maps öffnen
                </Button>
                <Button href={siteConfig.signupUrl}>
                    Probetraining anfragen
                </Button>
            </div>
        </div>

        <div class="flex h-full p-2 md:p-3">
            <div
                class="relative flex h-full w-full overflow-hidden rounded-[1.45rem] border border-[var(--color-line)] bg-white shadow-[var(--shadow-strong)]"
            >
                <div
                    class="pointer-events-none absolute inset-x-0 top-0 z-10 h-16 bg-[linear-gradient(180deg,rgba(255,252,247,0.2),transparent)]"
                    aria-hidden="true"
                >
                </div>
                <iframe
                    src={mapsEmbedUrl}
                    title={title}
                    loading="lazy"
                    referrerpolicy="strict-origin-when-cross-origin"
                    allowfullscreen
                    class:list={["w-full flex-1 border-0 bg-white", iframeClassName]}
                ></iframe>
            </div>
        </div>
    </div>
</div>
