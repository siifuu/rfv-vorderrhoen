---
import { footerNav, siteConfig, socialLinks } from "@/lib/site";
---

<footer class="border-t border-[var(--color-line)] bg-[rgba(255,250,242,0.84)]">
  <div class="container-shell grid gap-10 py-12 md:grid-cols-[1.25fr_0.9fr_0.9fr_1.05fr]">
    <div class="prose-flow">
      <h2 class="text-2xl">{siteConfig.name}</h2>
      <p class="max-w-md text-[var(--color-soft-ink)]">
        {siteConfig.description}
      </p>
    </div>

    <div>
      <h3 class="mb-4 text-sm font-semibold uppercase tracking-[0.16em] text-[var(--color-moss)]">Navigation</h3>
      <ul class="space-y-3 text-sm text-[var(--color-soft-ink)]">
        {footerNav.map((item) => (
          <li><a class="transition hover:text-[var(--color-forest)]" href={item.href}>{item.label}</a></li>
        ))}
      </ul>
    </div>

    <div>
      <h3 class="mb-4 text-sm font-semibold uppercase tracking-[0.16em] text-[var(--color-moss)]">Kontakt</h3>
      <ul class="space-y-3 text-sm text-[var(--color-soft-ink)]">
        <li>{siteConfig.location}</li>
        <li><a href={`mailto:${siteConfig.email}`}>{siteConfig.email}</a></li>
        <li><a href={`tel:${siteConfig.phone.replace(/\s+/g, "")}`}>{siteConfig.phone}</a></li>
      </ul>
    </div>

    <div>
      <h3 class="mb-4 text-sm font-semibold uppercase tracking-[0.16em] text-[var(--color-moss)]">Socials</h3>
      <ul class="space-y-3 text-sm text-[var(--color-soft-ink)]">
        {socialLinks.map((item) => (
          <li>
            <a
              class="block rounded-[1.1rem] border border-[var(--color-line)] bg-white/50 px-4 py-3 transition hover:border-[var(--color-moss)] hover:text-[var(--color-forest)]"
              href={item.href}
              target="_blank"
              rel="noreferrer"
            >
              <span class="block text-xs uppercase tracking-[0.14em] text-[var(--color-moss)]">
                {item.platform}
              </span>
              <span class="mt-1 block font-semibold text-[var(--color-ink)]">{item.label}</span>
              <span class="mt-1 block">{item.handle}</span>
            </a>
          </li>
        ))}
      </ul>
    </div>
  </div>
</footer>
